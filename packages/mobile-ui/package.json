{
  "name": "@fg-design-system/mobile-ui",
  "version": "0.1.0",
  "description": "FG Design System - Mobile UI (React Native/Expo)",
  "private": false,
  "main": "src/index.ts",
  "module": "src/index.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "src",
    "components",
    "tailwind.config.js",
    "global.css",
    "nativewind-env.d.ts"
  ],
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "react-native": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./tailwind": {
      "default": "./tailwind.config.js"
    },
    "./global.css": {
      "default": "./global.css"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@gluestack-ui/core": ">=3.0.0",
    "@legendapp/motion": ">=2.4.0",
    "nativewind": ">=4.2.0",
    "react": ">=19.0.0",
    "react-native": ">=0.85.0",
    "react-native-reanimated": ">=4.1.0",
    "react-native-safe-area-context": ">=5.6.0",
    "react-native-svg": ">=15.12.0",
    "react-native-worklets": ">=0.5.0"
  },
  "dependencies": {
    "@expo/html-elements": "^0.10.1",
    "@gluestack-ui/utils": "^3.0.21",
    "react-aria": "^3.48.0",
    "react-stately": "^3.46.0",
    "tailwind-variants": "^0.1.20"
  },
  "devDependencies": {
    "babel-plugin-module-resolver": "^5.0.3",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "tailwindcss": "^3.4.19"
  }
}
