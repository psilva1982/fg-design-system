    "react-native-svg": "15.15.5",
    "react-native-worklets": "^0.5.2",
    "react-stately": "^3.46.0",
    "tailwind-variants": "^0.1.20"
  },
  "devDependencies": {
    "babel-plugin-module-resolver": "^5.0.3",
