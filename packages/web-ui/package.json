{
  "name": "@fg-design-system/web-ui",
  "version": "0.1.0",
  "description": "FG Design System - Web UI (React)",
  "private": false,
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
